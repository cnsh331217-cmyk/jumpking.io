class SwitchButton(BasePlatform):
    def __init__(self, px, py, b_id, align="left"):
        super().__init__(px, py, 12, 24, (0,0,0,0))
        self.b_id = b_id
        self.align = align
        self.is_button = True
        self.is_pressed = (b_id in global_pressed_buttons)
        self.draw_button()

    def draw_button(self):
        self.image.fill((0,0,0,0))
        color = (50, 200, 50) if self.is_pressed else (255, 50, 50)
        w = 6 if self.is_pressed else 12 
        
        if self.align == "left":
            pygame.draw.rect(self.image, color, (0, 0, w, 24))
            pygame.draw.rect(self.image, WHITE, (0, 0, w, 24), 2)
        else: 
            offset = 12 - w
            pygame.draw.rect(self.image, color, (offset, 0, w, 24))
            pygame.draw.rect(self.image, WHITE, (offset, 0, w, 24), 2)
            
        self.mask = pygame.mask.from_surface(self.image)

    def press(self):
        if not self.is_pressed:
            self.is_pressed = True
            self.draw_button() 
            global_pressed_buttons.add(self.b_id)

