def draw_background(surface, camera_y):
    surface.fill((5, 10, 25)) 
    for sx, sy in STARS:
        if -2 < sy - camera_y < GAME_H + 2:
            surface.set_at((int(sx), int(sy - camera_y)), WHITE)

    brick_w, brick_h = 25, 12 
    start_row = int(camera_y // brick_h) - 1
    end_row = int((camera_y + GAME_H) // brick_h) + 2
    
    for row in range(start_row, end_row):
        y_world = row * brick_h
        if y_world >= ROOFTOP_Y: 
            y_screen = y_world - camera_y
            offset_x = (row % 2) * (brick_w // 2)
            
            for col in range(-1, GAME_W // brick_w + 2):
                x = col * brick_w - offset_x
                wall_col = (45, 50, 55) if row % 2 == 0 else (50, 55, 60)
                pygame.draw.rect(surface, wall_col, (x, y_screen, brick_w-1, brick_h-1))
                if (row * 37 + col * 17) % 100 < 8: 
                    pygame.draw.rect(surface, (15, 20, 35), (x+5, y_screen+3, brick_w-11, brick_h-7))
                    surface.set_at((int(x+7), int(y_screen+5)), (200, 200, 100))

    roof_screen_y = ROOFTOP_Y - camera_y
    if -10 < roof_screen_y < GAME_H:
        for px in range(0, GAME_W, 15):
            if px < GAME_W//2 - 25 or px > GAME_W//2 + 15:
                pygame.draw.rect(surface, (60, 65, 70), (px, roof_screen_y - 8, 10, 8))
        pygame.draw.rect(surface, NORMAL_COLOR, (0, roof_screen_y, GAME_W//2 - 25, 3))
        pygame.draw.rect(surface, NORMAL_COLOR, (GAME_W//2 + 25, roof_screen_y, GAME_W//2 - 25, 3))

# ================= [ 플랫폼 및 트랩 클래스 ] =================
P_THICK = 25 * SCALE_F 

class BasePlatform(pygame.sprite.Sprite):
    def __init__(self, px, py, pw, ph, color, flat_top=False):
        super().__init__()
        self.image = pygame.Surface((pw, ph), pygame.SRCALPHA)
        self.image.fill(color)
        if flat_top: 
            pygame.draw.line(self.image, GREEN, (0, 0), (pw, 0), 1)
        self.rect = self.image.get_rect(topleft=(px, py))
        self.mask = pygame.mask.from_surface(self.image)
        self.is_slippery = False
        self.is_illusion = False
        self.is_hazard = False
        self.is_moving = False

class Platform(BasePlatform):
    def __init__(self, px, py, pw): 
        super().__init__(px, py, pw, int(P_THICK), NORMAL_COLOR, flat_top=True)

class SlipperyPlatform(BasePlatform):
    def __init__(self, px, py, pw):
        super().__init__(px, py, pw, int(P_THICK), ICE_COLOR, flat_top=True)
        self.is_slippery = True

class IllusionPlatform(BasePlatform):
    def __init__(self, px, py, pw):
        super().__init__(px, py, pw, int(P_THICK), (0,0,0,0), flat_top=True)
        self.is_illusion = True
        self.is_active = True
        self.vanish_timer = 0
        self.reappear_timer = 0
        self.raw_color = ILLUSION_COLOR
        self.w = pw
        self.h = int(P_THICK)
        self.redraw(150)
        
    def redraw(self, alpha):
        self.image.fill((0,0,0,0))
        img = pygame.Surface((self.w, self.h))
        img.fill(self.raw_color)
        img.set_alpha(alpha)
        self.image.blit(img, (0,0))
        pygame.draw.line(self.image, GREEN, (0, 0), (self.w, 0), 1)

    def step_on(self):
        if self.is_active and self.vanish_timer == 0: 
            self.vanish_timer = 60
            
    def update(self):
        if self.is_active:
            if self.vanish_timer > 0:
                self.vanish_timer -= 1
                if self.vanish_timer < 20 and self.vanish_timer % 8 == 0: 
                    self.redraw(50)
                else: 
                    self.redraw(150)
                if self.vanish_timer == 0:
                    self.is_active = False
                    self.reappear_timer = 150
                    self.redraw(0)
        else:
            self.reappear_timer -= 1
            if self.reappear_timer <= 0:
                self.is_active = True
                self.vanish_timer = 0
                self.redraw(150)

class MovingPlatform(BasePlatform):
    def __init__(self, py, pw):
        max_x = max(0, GAME_W - pw)
        super().__init__(random.randint(0, max_x), py, pw, int(P_THICK), MOVING_PLAT_COLOR, flat_top=True)
        self.is_moving = True
        self.direction = random.choice([-1, 1])
        self.speed = random.uniform(0.6, 1.2)
        self.exact_x = float(self.rect.x)
        
    def update(self):
        self.exact_x += self.direction * self.speed
        self.rect.x = int(self.exact_x)
        if self.rect.right > GAME_W or self.rect.left < 0: 
            self.direction *= -1
            self.exact_x += self.direction * self.speed * 2

