class Laser(BasePlatform):
    def __init__(self, py):
        super().__init__(0, py, GAME_W, 4, (0,0,0,0))
        self.is_hazard = True
        self.hazard_type = "laser"
        self.timer = random.randint(0, 120)
        self.state = 0
        
    def update(self):
        self.timer += 1
        self.image.fill((0,0,0,0))
        if self.state == 0:
            if self.timer > 90: 
                self.state = 1
                self.timer = 0
        elif self.state == 1:
            for x in range(0, GAME_W, 4): 
                pygame.draw.rect(self.image, (255, 100, 100, 180), (x, 1, 2, 2))
            if self.timer > 40: 
                self.state = 2
                self.timer = 0
        elif self.state == 2:
            self.image.fill(LASER_HOT)
            pygame.draw.rect(self.image, WHITE, (0, 1, GAME_W, 2))
            if self.timer > 60: 
                self.state = 0
                self.timer = 0
        self.mask = pygame.mask.from_surface(self.image)

